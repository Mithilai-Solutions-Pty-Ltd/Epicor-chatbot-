# BOTZI – .gitignore
# ── Secrets (NEVER commit these) ──────────────────────────
.env
*.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/

# ── VS Code ───────────────────────────────────────────────
.vscode/settings.json

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Temp files ────────────────────────────────────────────
tmp/
temp/
*.tmp
